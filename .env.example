# LLM 差异分析器环境变量配置
# 复制此文件为 .env 并填入实际值

# ROUTIN 配置 (用于分析和问题生成)
ROUTIN_API_KEY=your-routin-api-key-here

# NVIDIA 配置
NVIDIA_API_KEY_1=your-nvidia-api-key-1-here
NVIDIA_API_KEY_2=your-nvidia-api-key-2-here

# MODAL 配置
MODAL_API_KEY_1=your-modal-api-key-1-here
MODAL_API_KEY_2=your-modal-api-key-2-here

# IFLOW_CN 配置
IFLOW_CN_API_KEY=your-iflow-cn-api-key-here

# IFLOW_ROME 配置
IFLOW_ROME_API_KEY=your-iflow-rome-api-key-here

# ZENMUX 配置
ZENMUX_API_KEY=your-zenmux-api-key-here

# OpenAI 默认配置 (可选，作为后备)
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_BASE_URL=https://api.openai.com/v1
